{
  "name": "vocab-observatory-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.0 <23",
    "npm": ">=10.9.0 <11"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage && npm run coverage:layered",
    "coverage:layered": "tsx scripts/report-layered-coverage.ts",
    "complexity:routes": "tsx scripts/verify-route-complexity.ts",
    "test:watch": "vitest",
    "api:openapi": "tsx scripts/generate-openapi.ts",
    "api:client:generate": "tsx scripts/generate-openapi-client.ts",
    "api:client:check": "tsx scripts/check-openapi-client.ts",
    "api:contract": "vitest run tests/http/openapi-contract.test.ts --coverage.enabled=false",
    "api:breaking": "tsx scripts/verify-openapi-breaking.ts",
    "api:breaking:contract": "vitest run tests/scripts/verify-openapi-breaking.test.ts --coverage.enabled=false",
    "api:governance": "npm run api:openapi && npm run api:client:check && npm run api:contract && npm run api:breaking && npm run api:breaking:contract && npm run complexity:routes",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:db-release": "tsx scripts/verify-release-database.ts",
    "test:capacity": "tsx scripts/verify-capacity.ts",
    "test:db-roles": "tsx scripts/verify-database-roles.ts",
    "alerting:verify": "tsx scripts/verify-alerting-contract.ts",
    "alerting:contract": "vitest run tests/scripts/verify-alerting-contract.test.ts --coverage.enabled=false",
    "release:manifest": "tsx scripts/generate-release-manifest.ts",
    "release:manifest:verify": "tsx scripts/verify-release-manifest.ts",
    "release:smoke": "tsx scripts/verify-deployment-smoke.ts",
    "release:deploy": "tsx scripts/deploy-compose-release.ts",
    "release:deploy:contract": "vitest run tests/scripts/deploy-compose-release.test.ts --coverage.enabled=false",
    "release:check:evidence": "tsx scripts/release-check-evidence.ts",
    "release:acceptance:verify": "tsx scripts/verify-production-release-acceptance.ts",
    "release:acceptance:contract": "vitest run tests/scripts/verify-production-release-acceptance.test.ts --coverage.enabled=false",
    "secret-rotation:evidence:verify": "tsx scripts/verify-secret-rotation-evidence.ts",
    "secret-rotation:evidence:contract": "vitest run tests/scripts/verify-secret-rotation-evidence.test.ts --coverage.enabled=false",
    "release:workflow:verify": "tsx scripts/verify-release-workflow.ts",
    "release:workflow:contract": "vitest run tests/scripts/verify-release-workflow.test.ts --coverage.enabled=false",
    "release:rollback-check": "tsx scripts/verify-rollback-compatibility.ts",
    "alerting:drill": "tsx scripts/run-alerting-drill.ts",
    "alerting:drill:contract": "vitest run tests/scripts/run-alerting-drill.test.ts --coverage.enabled=false",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:schema:drift": "tsx scripts/verify-schema-drift.ts",
    "db:adopt-release-baseline": "tsx scripts/adopt-release-baseline.ts",
    "db:backup": "tsx scripts/postgres-backup.ts create",
    "db:backup:verify": "tsx scripts/postgres-backup.ts verify",
    "db:restore:drill": "tsx scripts/postgres-backup.ts restore-drill",
    "runtime:verify": "tsx scripts/verify-container-runtime.ts",
    "runtime:smoke:local": "tsx scripts/verify-local-compose-smoke.ts",
    "runtime:build": "docker compose build",
    "runtime:up": "docker compose up -d",
    "runtime:down": "docker compose down",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "worker:review-outbox": "tsx scripts/run-review-outbox-worker.ts",
    "outbox:metrics": "tsx scripts/review-outbox-admin.ts metrics",
    "outbox:replay": "tsx scripts/review-outbox-admin.ts replay",
    "worker:llm-reservation-reaper": "tsx scripts/run-llm-reservation-reaper.ts",
    "backup:scheduler": "tsx scripts/run-backup-scheduler.ts",
    "data:lifecycle:dry-run": "tsx scripts/run-data-lifecycle.ts",
    "data:lifecycle:run": "tsx scripts/run-data-lifecycle.ts --execute",
    "test:data-lifecycle": "vitest run --config vitest.integration.config.ts --reporter=verbose tests/repositories/data-lifecycle.integration.test.ts",
    "llm-reservation:metrics": "tsx scripts/llm-reservation-admin.ts metrics",
    "llm-reservation:reap": "tsx scripts/llm-reservation-admin.ts run-once",
    "db:script:backfill-hashes": "tsx scripts/backfill-content-hash.ts",
    "dev": "tsx watch src/server.ts",
    "frontend:dev": "vite --host 127.0.0.1",
    "frontend:build": "tsc --noEmit -p tsconfig.frontend.json && vite build",
    "arch:check": "depcruise src --config .dependency-cruiser.cjs",
    "arch:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > arch.svg",
    "verify": "npm run verify:engineering",
    "verify:engineering": "npm run typecheck && npm run arch:check && npm run test:unit && npm run db:schema:drift && npm run api:governance && npm run frontend:build && npm run runtime:verify && npm run alerting:verify && npm run release:acceptance:contract && npm run secret-rotation:evidence:contract && npm run release:workflow:verify",
    "verify:unit": "npm run verify:engineering",
    "verify:db": "npm run db:migrate && npm run test:db-release && npm run test:integration && npm run test:db-roles && npm run test:capacity",
    "test:integration:auth": "tsx scripts/verify-browser-auth-e2e.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:auth": "tsx scripts/verify-browser-auth-e2e.ts",
    "verify:e2e": "npx playwright test",
    "verify:release": "npm run verify:engineering && npm run verify:db && npm run verify:e2e",
    "verify:check": "npm run typecheck && npm run complexity:routes && npm run test:unit",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:verify": "node scripts/verify-supply-chain.mjs && npm run security:audit",
    "sbom:npm": "cyclonedx-npm --output-format JSON --spec-version 1.6 --output-file sbom-npm.cdx.json --validate",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@hono/node-server": "^2.0.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "openai": "^6.45.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-fsrs": "^5.4.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^18.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5",
    "vite": "^8.1.3",
    "vitest": "^4.1.5",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit -p tsconfig.json'"
    ]
  }
}
