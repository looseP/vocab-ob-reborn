# Copy these values into the same untracked Windows .env used by compose.single-host.yaml.
# This optional overlay exposes no Windows host ports. Do not commit the resulting .env.
# The public hostname must be configured in Cloudflare Tunnel as http://caddy:80.
# Cloudflare terminates public TLS at the edge; Caddy is reachable only on Docker's public network.

# Resolve and review an immutable cloudflared image digest before deployment.
CLOUDFLARED_IMAGE=cloudflare/cloudflared@sha256:REPLACE_WITH_64_HEX_DIGEST
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN

# Replace with the Cloudflare-managed public hostname for this personal service.
CADDY_SITE_ADDRESS=vocab.example.com
APP_ORIGIN=https://vocab.example.com
# This path is resolved relative to the Docker Compose project directory.
CADDY_CONFIG_FILE=./Caddyfile.cloudflare-tunnel
