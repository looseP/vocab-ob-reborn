# Disposable PostgreSQL 17 environment for RLS acceptance only.
# This never changes compose.yaml, production URL variables, or runtime database roles.
RLS_ACCEPTANCE_ADMIN_USER=vocab_rls_admin
RLS_ACCEPTANCE_ADMIN_PASSWORD=vocab_rls_admin_local_only
RLS_ACCEPTANCE_DATABASE=vocab_rls_acceptance
RLS_ACCEPTANCE_PORT=55433

# Used only by tests after migrate and test-role bootstrap complete.
TEST_DATABASE_URL=postgresql://vocab_rls_admin:vocab_rls_admin_local_only@127.0.0.1:55433/vocab_rls_acceptance
RLS_ACCEPTANCE_DATABASE_URL=postgresql://vocab_rls_acceptance:vocab_rls_acceptance_local_only@127.0.0.1:55433/vocab_rls_acceptance
DB_SSLMODE=disable
DB_POOL_MAX=1
