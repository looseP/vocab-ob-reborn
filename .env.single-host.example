# Copy to .env on the Linux host, replace every placeholder, then run: chmod 600 .env
# Never commit the resulting .env file. All application images must be immutable digests.
APP_IMAGE=ghcr.io/OWNER/vocab-observatory-runtime@sha256:REPLACE_WITH_64_HEX_DIGEST
MIGRATION_IMAGE=ghcr.io/OWNER/vocab-observatory-migration@sha256:REPLACE_WITH_64_HEX_DIGEST
BACKUP_IMAGE=ghcr.io/OWNER/vocab-observatory-backup@sha256:REPLACE_WITH_64_HEX_DIGEST
# Pin Caddy to the digest resolved for the reviewed 2.10.2-alpine release.
CADDY_IMAGE=caddy@sha256:REPLACE_WITH_64_HEX_DIGEST
POSTGRES_IMAGE=postgres@sha256:REPLACE_WITH_64_HEX_DIGEST

# Public HTTPS endpoint. DNS A/AAAA records must already target this host.
CADDY_EMAIL=admin@example.com
CADDY_SITE_ADDRESS=vocab.example.com
APP_ORIGIN=https://vocab.example.com

# Generate unique random values. Do not reuse development defaults.
POSTGRES_USER=vocab
POSTGRES_PASSWORD=REPLACE_WITH_LONG_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=vocab
OWNER_API_TOKEN=REPLACE_WITH_AT_LEAST_24_RANDOM_CHARACTERS
METRICS_BEARER_TOKEN=REPLACE_WITH_A_DISTINCT_24_RANDOM_CHARACTERS
LOCAL_OWNER_ID=00000000-0000-4000-8000-000000000001
BACKUP_SIGNING_KEY=REPLACE_WITH_LONG_RANDOM_SIGNING_KEY

# Must be an absolute host path, owned by the account that runs Docker.
BACKUP_HOST_DIR=/srv/vocab-observatory/backups
BACKUP_RUNTIME_USER=1000:1000
BACKUP_INTERVAL_MS=86400000
BACKUP_RETENTION_COUNT=14
DB_POOL_MAX=5
LOG_LEVEL=info
READINESS_TIMEOUT_MS=500
SHUTDOWN_GRACE_MS=25000
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_ATTEMPTS=8
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=60
OUTBOX_SHUTDOWN_GRACE_SECONDS=75
OUTBOX_STOP_GRACE_PERIOD=75s
LLM_REAPER_POLL_INTERVAL_MS=5000
LLM_REAPER_BATCH_SIZE=100

# Optional external enrichment. Keep blank to disable.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
DATAMUSE_ENABLED=false
