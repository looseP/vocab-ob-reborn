APP_IMAGE=vocab-observatory-v2:local
MIGRATION_IMAGE=vocab-observatory-v2-migration:local
BACKUP_IMAGE=vocab-observatory-v2-backup:local
APP_PORT=3001
APP_NODE_ENV=production
APP_ORIGIN=https://vocab.example.com
OWNER_API_TOKEN=replace-with-at-least-24-random-characters
METRICS_BEARER_TOKEN=replace-with-a-distinct-24-character-token
LOCAL_OWNER_ID=00000000-0000-4000-8000-000000000001

POSTGRES_USER=vocab
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=vocab

# Production: use separate least-privilege roles, not the database owner.
# Each service should receive only its own connection string.
# Development: DATABASE_URL with the owner credential is accepted for convenience.
DATABASE_URL=postgresql://vocab:replace-with-a-strong-database-password@postgres:5432/vocab

# Separate role URLs (production). Create these roles in the managed database
# control plane or infrastructure-as-code; the CI role test verifies the
# permission model. Each URL must include sslmode=require in production.
APP_DATABASE_URL=postgresql://app_role:replace-with-a-strong-database-password@postgres:5432/vocab
WORKER_DATABASE_URL=postgresql://worker_role:replace-with-a-strong-database-password@postgres:5432/vocab
BACKUP_DATABASE_URL=postgresql://backup_role:replace-with-a-strong-database-password@postgres:5432/vocab
MIGRATION_DATABASE_URL=postgresql://migration_role:replace-with-a-strong-database-password@postgres:5432/vocab

# Optional: enforce TLS to the database in production by setting DB_SSLMODE.
# Valid values: disable, require, verify-ca, verify-full.
# Production should use verify-full with a mounted CA certificate.
DB_SSLMODE=disable
DB_POOL_MAX=5
LOG_LEVEL=info

# Data lifecycle one-shot job (use a dedicated least-privilege role; no DATABASE_URL fallback)
DATA_LIFECYCLE_DATABASE_URL=postgresql://lifecycle_role:replace-with-a-strong-database-password@postgres:5432/vocab
# Every run requires an approved canonical UTC cutoff; write confirmations remain empty for dry-run.
DATA_LIFECYCLE_CUTOFF=2026-01-01T00:00:00.000Z
# Leave empty during dry-run; execution must copy DATA_LIFECYCLE_CUTOFF exactly.
DATA_LIFECYCLE_CONFIRM_CUTOFF=
DATA_LIFECYCLE_CONFIRM=
DATA_LIFECYCLE_ALLOW_WRITE=
# Required for execute: development, test, staging, or production. Do not substitute NODE_ENV.
DATA_LIFECYCLE_ENVIRONMENT=
DATA_LIFECYCLE_PRODUCTION_CONFIRM=
DATA_LIFECYCLE_OUTBOX_PROCESSED_DAYS=30
DATA_LIFECYCLE_AUTH_SESSION_DAYS=30
DATA_LIFECYCLE_LLM_TERMINAL_DAYS=30
DATA_LIFECYCLE_LLM_SETTLED_DAYS=400
DATA_LIFECYCLE_REVIEW_LOG_DAYS=365
DATA_LIFECYCLE_BATCH_SIZE=250
DATA_LIFECYCLE_MAX_BATCHES=100
DATA_LIFECYCLE_MAX_ROWS=25000
DATA_LIFECYCLE_LOCK_TIMEOUT_MS=2000
DATA_LIFECYCLE_STATEMENT_TIMEOUT_MS=30000

READINESS_TIMEOUT_MS=500
SHUTDOWN_GRACE_MS=25000
TRUST_PROXY=false
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_ATTEMPTS=8
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=60
OUTBOX_SHUTDOWN_GRACE_SECONDS=75
OUTBOX_STOP_GRACE_PERIOD=75s
LLM_REAPER_POLL_INTERVAL_MS=5000
LLM_REAPER_BATCH_SIZE=100

# Backup scheduler
BACKUP_DIR=/backups
BACKUP_INTERVAL_MS=86400000
BACKUP_RETENTION_COUNT=14
BACKUP_SIGNING_KEY=replace-with-a-strong-signing-key
BACKUP_REQUIRE_SIGNING_KEY=true
BACKUP_OBJECT_LOCK=true
BACKUP_HOST_DIR=backups
POSTGRES_CLIENT_MAJOR=17

LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
DATAMUSE_ENABLED=false
