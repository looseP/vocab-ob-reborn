APP_IMAGE=vocab-observatory-v2:local
MIGRATION_IMAGE=vocab-observatory-v2-migration:local
APP_PORT=3001
APP_NODE_ENV=production
APP_ORIGIN=https://vocab.example.com
OWNER_API_TOKEN=replace-with-at-least-24-random-characters
LOCAL_OWNER_ID=00000000-0000-4000-8000-000000000001

POSTGRES_USER=vocab
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=vocab
DATABASE_URL=postgresql://vocab:replace-with-a-strong-database-password@postgres:5432/vocab
DB_POOL_MAX=5
LOG_LEVEL=info

READINESS_TIMEOUT_MS=500
SHUTDOWN_GRACE_MS=25000
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=60
OUTBOX_SHUTDOWN_GRACE_SECONDS=75
OUTBOX_STOP_GRACE_PERIOD=75s
LLM_REAPER_POLL_INTERVAL_MS=5000
LLM_REAPER_BATCH_SIZE=100

LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
DATAMUSE_ENABLED=false
