# Safe local-development defaults. These example credentials are local-only;
# never reuse them in staging or production.
APP_IMAGE=vocab-observatory-v2:local
MIGRATION_IMAGE=vocab-observatory-v2-migration:local
BACKUP_IMAGE=vocab-observatory-v2-backup:local
APP_PORT=3001
APP_NODE_ENV=development
APP_ORIGIN=http://127.0.0.1:3001
OWNER_API_TOKEN=local-owner-api-token-only-0001
LOCAL_OWNER_ID=00000000-0000-4000-8000-000000000001

POSTGRES_USER=vocab
POSTGRES_PASSWORD=vocab
POSTGRES_DB=vocab
DATABASE_URL=postgresql://vocab:vocab@postgres:5432/vocab
DB_SSLMODE=disable
DB_POOL_MAX=5
LOG_LEVEL=info

# Standalone production Compose: docker compose -f compose.production.yaml ...
# Do not combine it with compose.yaml, which contains the local PostgreSQL service.
# Supply every value below from production secret/config management. Production
# rendering fails before startup when any required image, role URL, path, or secret
# is absent. APP_ORIGIN must be HTTPS; DB_SSLMODE is fixed to verify-full and
# requires the appropriate CA trust configuration.
# APP_IMAGE=registry.example.com/vocab-runtime@sha256:<digest>
# MIGRATION_IMAGE=registry.example.com/vocab-migration@sha256:<digest>
# BACKUP_IMAGE=registry.example.com/vocab-backup@sha256:<digest>
# APP_DATABASE_URL=postgresql://vocab_app:SECRET@db.example.com:5432/vocab?sslmode=verify-full
# WORKER_DATABASE_URL=postgresql://vocab_worker:SECRET@db.example.com:5432/vocab?sslmode=verify-full
# BACKUP_DATABASE_URL=postgresql://vocab_backup:SECRET@db.example.com:5432/vocab?sslmode=verify-full
# MIGRATION_DATABASE_URL=postgresql://vocab_migration:SECRET@db.example.com:5432/vocab?sslmode=verify-full
# APP_ORIGIN=https://vocab.example.com
# OWNER_API_TOKEN=<at-least-24-random-characters>
# METRICS_BEARER_TOKEN=<distinct-at-least-24-random-characters>
# LOCAL_OWNER_ID=<production-owner-uuid>
# BACKUP_SIGNING_KEY=<strong-production-signing-key>
# BACKUP_DIR=/backups
# BACKUP_HOST_DIR=/var/lib/vocab-observatory/backups

# Data lifecycle one-shot job remains opt-in and never inherits DATABASE_URL.
DATA_LIFECYCLE_DATABASE_URL=
DATA_LIFECYCLE_CUTOFF=2026-01-01T00:00:00.000Z
DATA_LIFECYCLE_CONFIRM_CUTOFF=
DATA_LIFECYCLE_CONFIRM=
DATA_LIFECYCLE_ALLOW_WRITE=
DATA_LIFECYCLE_ENVIRONMENT=
DATA_LIFECYCLE_PRODUCTION_CONFIRM=
DATA_LIFECYCLE_OUTBOX_PROCESSED_DAYS=30
DATA_LIFECYCLE_AUTH_SESSION_DAYS=30
DATA_LIFECYCLE_LLM_TERMINAL_DAYS=30
DATA_LIFECYCLE_LLM_SETTLED_DAYS=400
DATA_LIFECYCLE_REVIEW_LOG_DAYS=365
DATA_LIFECYCLE_BATCH_SIZE=250
DATA_LIFECYCLE_MAX_BATCHES=100
DATA_LIFECYCLE_MAX_ROWS=25000
DATA_LIFECYCLE_LOCK_TIMEOUT_MS=2000
DATA_LIFECYCLE_STATEMENT_TIMEOUT_MS=30000

READINESS_TIMEOUT_MS=500
SHUTDOWN_GRACE_MS=25000
TRUST_PROXY=false
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_ATTEMPTS=8
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=60
OUTBOX_SHUTDOWN_GRACE_SECONDS=75
OUTBOX_STOP_GRACE_PERIOD=75s
LLM_REAPER_POLL_INTERVAL_MS=5000
LLM_REAPER_BATCH_SIZE=100

BACKUP_DIR=/backups
BACKUP_INTERVAL_MS=86400000
BACKUP_RETENTION_COUNT=14
BACKUP_SIGNING_KEY=local-backup-signing-key-only-0001
BACKUP_REQUIRE_SIGNING_KEY=true
BACKUP_OBJECT_LOCK=true
BACKUP_HOST_DIR=./backups

LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
DATAMUSE_ENABLED=false
